<style>
  @keyframes tardis-jump {
    0% {
      transform: translateY(0);
    }
    35% {
      transform: translateY(-16px);
    }
    60% {
      transform: translateY(-7px);
    }
    80% {
      transform: translateY(-2px);
    }
    100% {
      transform: translateY(0);
    }
  }

  #tardis-egg.jumping {
    animation: tardis-jump 0.45s ease-out both;
  }

  #tardis-egg:hover img {
    filter: drop-shadow(0 4px 14px rgba(0, 62, 116, 0.55)) !important;
  }

  @media (prefers-reduced-motion: reduce) {
    #tardis-egg.jumping {
      animation: none;
    }
  }
</style>

<script>
  (function () {
    var el = document.getElementById('tardis-egg');
    var img = document.getElementById('tardis-img');
    if (!el || !img) return;

    var gifs = ['{{ "/assets/gif/TARDIS.gif" | relative_url }}', '{{ "/assets/gif/Penguin.gif" | relative_url }}'];
    var current = 0;

    el.addEventListener('click', function () {
      el.classList.remove('jumping');
      void el.offsetWidth; // force reflow to restart animation
      el.classList.add('jumping');
    });

    el.addEventListener('animationend', function () {
      el.classList.remove('jumping');
      current = (current + 1) % gifs.length;
      img.src = gifs[current];
      // Update tooltip to match current character
      el.title = current === 0 ? "...it's bigger on the inside." : 'Waddle on.';
    });
  })();
</script>
