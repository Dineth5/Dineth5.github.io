<!doctype html>
<html lang="{{ site.lang }}">
  <head>
    {% if page.redirect %}
      {% if page.redirect == true %}
        {% assign redirect = site.baseurl | append: '/' %}
      {% elsif page.redirect contains '://' %}
        {% assign redirect = page.redirect %}
      {% else %}
        {% assign redirect = page.redirect | relative_url %}
      {% endif %}
      <meta http-equiv="refresh" content="3; url={{ redirect }}">
    {% endif %}

    {% include head.liquid %}

    <!-- Canonical -->
    <link rel="canonical" href="{{ site.url }}{{ page.url }}">

    <!-- Inter + JetBrains Mono -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
    >
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
    >

    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-BB14DEZMRD"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag('js', new Date());
      gtag('config', 'G-BB14DEZMRD');
    </script>
  </head>

  <body class="{% if site.navbar_fixed %}fixed-top-nav{% endif %} {% unless site.footer_fixed %}sticky-bottom-footer{% endunless %}">
    <!-- Custom cursor elements (hidden on touch) -->
    <div class="cursor-dot" aria-hidden="true"></div>
    <div class="cursor-ring" aria-hidden="true"></div>

    <!-- Header -->
    {% include header.liquid %}

    <!-- Main content -->
    <main role="main">
      {% if page.layout == 'about' %}
        {{- content -}}
      {% elsif page.toc and page.toc.sidebar %}
        <div class="container mt-5">
          {% if page.toc.sidebar == 'right' %}
            <div class="row">
              <div class="col-sm-9">{{ content }}</div>
              <div class="col-sm-3"><nav id="toc-sidebar" class="sticky-top"></nav></div>
            </div>
          {% else %}
            <div class="row">
              <div class="col-sm-3"><nav id="toc-sidebar" class="sticky-top"></nav></div>
              <div class="col-sm-9">{{ content }}</div>
            </div>
          {% endif %}
        </div>
      {% else %}
        <div class="container mt-5">{{ content }}</div>
      {% endif %}
    </main>

    <!-- Footer -->
    {% include footer.liquid %}

    <!-- al-folio scripts (dark mode toggle, search, etc.) -->
    {% include scripts.liquid %}

    <!-- Custom JS -->
    <script defer src="{{ '/assets/js/main.js' | relative_url | bust_file_cache }}"></script>

    {% if page.layout == 'about' or page.canvas == true %}
      <script defer src="{{ '/assets/js/hero-canvas.js' | relative_url | bust_file_cache }}"></script>
    {% endif %}
  </body>
</html>
